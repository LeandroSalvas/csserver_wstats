## Copy this file to ".env" and set strong values.
## Never commit your real ".env".

# --- MariaDB ---
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=csstats
MYSQL_USER=csuser
MYSQL_PASSWORD=change_me_user

# --- API ---
# If omitted, compose defaults DB_HOST to "db"
DB_HOST=db
SESSION_SECRET=change_me_to_a_long_random_string

# Comma-separated exact origins allowed to call the API with credentials.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:8080,http://192.168.15.54:8080
# If omitted, the API falls back to allowing: http://192.168.15.54:8080 (and any origin on port 8000).
CORS_ALLOWED_ORIGINS=

# --- Session store (Redis) ---
# Use "redis" (recommended) or "memory"
SESSION_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

